# NO se versionan). Los datos crudos sí se conservan.
# ------------------------------------------------------------
data/processed/
data/interim/
data/tmp/
*.log

# ------------------------------------------------------------
# Sistema operativo / editores
# ------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ------------------------------------------------------------
# Variables de entorno / secretos
# ------------------------------------------------------------
.env
.env.*
